# ─────────────────────────────────────────────────────────────────────
# ZiroWork Brain Agent — environment variables
#
# In Railway: set these as service Variables (no .env file needed).
# Locally:    copy this to .env at the repo root.
#
# NEVER commit .env. Use this .env.example for the schema only.
# ─────────────────────────────────────────────────────────────────────

# ── Required: API keys ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
APIFY_API_TOKEN=apify_api_...

# ── Required for Drive save (optional otherwise) ────────────────────
# Folder ID from drive.google.com/drive/folders/<ID>
GOOGLE_DRIVE_FOLDER_ID=

# Service account JSON, minified to a single line
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=

# Optional OAuth alternative to service-account JSON
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ── Required for public share mode ─────────────────────────────────
# Public users submit Instagram URL + email, receive markdown directly in
# the browser, and a hidden review copy is saved to Zach's Drive folder.
PUBLIC_SUBMISSIONS_ENABLED=true
PUBLIC_REVIEW_FOLDER_ID=

# Optional but recommended: capture public submitters in Kit.com.
# Kit API key auth uses the X-Kit-Api-Key header.
KIT_API_KEY=kit_...
KIT_FORM_ID=
KIT_TAG_ID=
KIT_REFERRER=https://zirowork.com/instagram-link-text-extractor

# Optional: route public review copies by importance. If blank, all public
# review copies fall back to PUBLIC_REVIEW_FOLDER_ID.
PUBLIC_HIGH_IMPORTANCE_FOLDER_ID=
PUBLIC_MEDIUM_IMPORTANCE_FOLDER_ID=
PUBLIC_LOW_IMPORTANCE_FOLDER_ID=

# ── Optional ────────────────────────────────────────────────────────
APPROVED_CREATORS=Andrew Huberman,Simon Willison,Andrej Karpathy
CONTENT_CATEGORIES=Agent Design,LLM Optimization,Product Strategy,AI Safety & Ethics,Technical Architecture,Business & Growth
CLAUDE_MODEL=claude-haiku-4-5-20251001
LOG_LEVEL=info

# Railway sets PORT automatically. Override only for local dev if 8000 is busy.
# PORT=8000

# Tighten in production by listing your domain(s); default "*" is fine for single-service.
# CORS_ALLOW_ORIGINS=https://your-app.up.railway.app
